@SolidClass = worldspawn : "World Entity" : ""
[
	message(string) : "Map Description / Title" : "" : "Used to show the map's title/description in the old WON interface."
	skyname(string) : "environment map (cl_skyname)" : "" : " Lets you choose what sky image you want."
	light(integer) : "Default light level" : 0 : ""
	WaveHeight(float) : "Default Wave Height" : "" : "Set the default wave height here (can be overridden by the properties in func_water)."
	MaxRange(integer) : "Max viewable distance" : 4096 : "Maximum distance the player can see in Hammer grid units; same as sv_zmax."
	chaptertitle(string) : "Chapter Title Message" : "The game logo will be displayed after the map loads." : "Text displayed when entering the level."
	startdark(choices) : "Level Fade In" : "0" : "" =
	[
		"0" : "No" : ""
		"1" : "Yes" : "The level will start black and fade into normal light."
	]
	gametitle(string) : "Game whose title to display" : "" : ""
	newunit(choices) : "New Level Unit" : "0" : "" =
	[
		"0" : "No, keep current" : ""
		"1" : "Yes, clear previous levels" : "All previous global triggers will be removed."
	]
	mapteams(string) : "Map Team List" : "grunt;scientist" : "This will be copied into the mp_teamlist while your map is running if the server allows maps to override the team list."
	defaultteam(choices) : "Default Team" : "0" : "" =
	[
		"0" : "Fewest Players" : ""
		"1" : "First Team" : ""
	]
	freeroam(choices) : "Roaming monsters (node graph)" : "0" : "" =
	[
		"0" : "No" : ""
		"1" : "Yes" : ""
	]
]

