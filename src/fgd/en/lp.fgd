@BaseClass = Mandatory
[
	spawnflags(Flags) =
	[
		2048 : "Not in Deathmatch" : 0 : "Only exists on a SinglePlayer game."
	]
	targetname(target_source) : "Name" : "" : ""
]

@BaseClass = Angles
[
	angles(vector) : "Pitch Yaw Roll (Y Z X)" : "0 0 0" : ""
]

@BaseClass = Target
[
	target(target_destination) : "Target" : "" : "Trigger multiple targets at once by using a semicolon to separate them, example 'This;That;Other' up to 8 targets"
	m_UseType(choices) : "Use Type" : "-1" : "Anything else will be count as USE_UNKNOWN and in fact, work the same as USE_UNSET" =
	[
		"-1" : "USE_UNSET (default)" : "This is the value by default and will have no effect at all in how entities normaly behave."
		"0" : "USE_OFF" : ""
		"1" : "USE_ON" : ""
		"2" : "USE_SET" : "Does use of m_UseValue, See how it affects each entity."
		"3" : "USE_TOGGLE" : ""
		"4" : "USE_KILL" : "Remove the entity from the world."
		"5" : "USE_SAME" : "Sends the same USE_TYPE that this entity receive."
		"6" : "USE_OPPOSITE" : "Sends the opposite USE_TYPE that this entity receive, Swaps USE_ON <-> USE_OFF, If anything else then USE_TOGGLE is sent"
		"7" : "USE_TOUCH" : "Calls the Touch function, the activator will be passed as the toucher."
		"8" : "USE_LOCK" : "Locks the entity. Does use of m_UseValue"
		"9" : "USE_UNLOCK" : "Un-Locks the entity. Does use of m_UseValue"
	]
	m_UseValue(float) : "Use Value" : "" : ""
]

