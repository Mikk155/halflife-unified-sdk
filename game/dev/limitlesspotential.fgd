	radius(integer) : "Player radius (for Radius target selector)" : "" : "If target_selector is Radius, this is how close the player has to be to be affected by this entity"
	remove_on_fire(choices) : "Remove on fire" : "0" : "Whether to remove the entity after it has been triggered or after it has affected at least one player (Radius only)" =
	[
		"0" : "No" : ""
		"1" : "Yes" : ""
	]
]

