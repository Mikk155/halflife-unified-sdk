@BaseClass size( -16 -16 0, 16 16 32 ) color( 0 0 200 ) studio() = CBaseItem
[
	respawn_delay(float) : "Respawn delay (-1 == Never)" : "-1" : "Custom respawn delay. If set, overrides the delay configured by the skill configuration. A delay of **-1** disables respawn. This allows items to respawn in singleplayer."
	stay_visible_during_respawn(choices) : "Stay Visible During Respawn" : "0" : "" =
	[
		"0" : "No" : "The items are invisible until respawn."
		"1" : "Yes" : "The item remains visible during the respawn time."
	]
	flash_on_respawn(choices) : "Flash On Respawn" : "1" : "" =
	[
		"0" : "No" : ""
		"1" : "Yes" : "The item will flash when it respawns."
	]
	play_pickup_sound(choices) : "Play Pickup Sound" : "1" : "" =
	[
		"0" : "No" : "The item won't play its pickup sound."
		"1" : "Yes" : "The item will play its pickup sound."
	]
	fall_mode(choices) : "Fall Mode" : "0" : "Controls whether the item falls to the ground or floats when it spawns." =
	[
		"0" : "Fall" : "Item falls to ground when it spawns"
		"1" : "Float" : "Item floats in the air where it spawns"
	]
	trigger_on_spawn(target_destination) : "Trigger On Spawn" : "" : "Target to trigger when the item (re)spawns."
	trigger_on_despawn(target_destination) : "Trigger On Despawn" : "" : "Target to trigger when the item despawns. This happens when the player picks up the item."
]

