		"5" : "USE_SAME" : "Sends the same USE_TYPE that this entity receive."
		"6" : "USE_OPPOSITE" : "Sends the opposite USE_TYPE that this entity receive, Swaps USE_ON  USE_OFF, If anything else then USE_TOGGLE is sent"
		"7" : "USE_TOUCH" : "Calls the Touch function, the activator will be passed as the toucher."
		"8" : "USE_LOCK" : "Locks the entity. Does use of m_UseValue"
		"9" : "USE_UNLOCK" : "Un-Locks the entity. Does use of m_UseValue"
