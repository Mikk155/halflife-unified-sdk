		"0" : "Default" : "This entity is not affected by the game being Cooperative"
		"1" : "Only in" : "This entity won't exist if the game is NOT Cooperative"
	]
	appearflag_skilleasy(choices) : "#AppearFlags Easy" : "0" : "Appearance flags for Skill level Easy, This control when this entity should or should not appear in this condition." =
	[
		"-1" : "Not in" : "This entity won't exist if the game is Easy."
		"0" : "Default" : "This entity is not affected by the game being Easy"
		"1" : "Only in" : "This entity won't exist if the game is NOT Easy"
	]
	appearflag_skillmedium(choices) : "#AppearFlags Medium" : "0" : "Appearance flags for Skill level Medium, This control when this entity should or should not appear in this condition." =
	[
		"-1" : "Not in" : "This entity won't exist if the game is Medium."
		"0" : "Default" : "This entity is not affected by the game being Medium"
		"1" : "Only in" : "This entity won't exist if the game is NOT Medium"
	]
	appearflag_skillhard(choices) : "#AppearFlags Hard" : "0" : "Appearance flags for Skill level Hard, This control when this entity should or should not appear in this condition." =
