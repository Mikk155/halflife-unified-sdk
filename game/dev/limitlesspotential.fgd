@BaseClass = appearflags
[
	appearflag_singleplayer(choices) : "#AppearFlags SinglePlayer" : "0" : "Appearance flags for SinglePlayer, This control when this entity should or should not appear in this condition." =
	[
		"-1" : "Not in" : "This entity won't exist if the game is SinglePlayer."
		"0" : "Default" : "This entity is not affected by the game being SinglePlayer"
		"1" : "Only in" : "This entity won't exist if the game is NOT SinglePlayer"
	]
	appearflag_multiplayer(choices) : "#AppearFlags MultiPlayer" : "0" : "Appearance flags for MultiPlayer, This control when this entity should or should not appear in this condition." =
	[
		"-1" : "Not in" : "This entity won't exist if the game is MultiPlayer."
		"0" : "Default" : "This entity is not affected by the game being MultiPlayer"
		"1" : "Only in" : "This entity won't exist if the game is NOT MultiPlayer"
	]
	appearflag_cooperative(choices) : "#AppearFlags Cooperative" : "0" : "Appearance flags for Cooperative, This control when this entity should or should not appear in this condition." =
