                {
                    "title": "USE_KILL",
                    "description": "Remove the entity from the world."
                },
                "5":
                {
                    "title": "USE_SAME",
                    "description": "Sends the same USE_TYPE that this entity receive."
                },
                "6":
                {
                    "title": "USE_OPPOSITE",
                    "description": "Sends the opposite USE_TYPE that this entity receive, Swaps USE_ON <-> USE_OFF, If anything else then USE_TOGGLE is sent"
                },
                "7":
                {
                    "title": "USE_TOUCH",
                    "description": "Calls the Touch function, the activator will be passed as the toucher."
                },
                "8":
                {
                    "title": "USE_LOCK",
                    "description": "Locks the entity. Does use of m_UseValue"
                },
                "9":
                {
